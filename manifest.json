{
  "manifest_version": 3,
  "name": "Contrast Checker",
  "version": "1.0.0",
  "description": "Check color contrast of elements in a selected region",
  "permissions": ["activeTab", "scripting", "menus"],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "contrast-checker@example.com",
      "strict_min_version": "109.0"
    }
  }
}
